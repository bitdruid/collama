{
    "name": "collama",
    "displayName": "collama",
    "description": "Use code auto completion provided by a local ollama instance",
    "repository": {
        "type": "git",
        "url": "https://github.com/bitdruid/collama.git"
    },
    "publisher": "bitdruid",
    "icon": "media/collama.png",
    "license": "MIT",
    "version": "1.8.16",
    "engines": {
        "vscode": "^1.120.0"
    },
    "categories": [
        "Other"
    ],
    "main": "./dist/extension.js",
    "activationEvents": [
        "onStartupFinished"
    ],
    "contributes": {
        "configuration": [
            {
                "title": "Autocomplete-API",
                "properties": {
                    "collama.apiEndpointCompletion": {
                        "type": "string",
                        "default": "",
                        "markdownDescription": "API endpoint for auto-completion.\n\nStarts with `http://` or `https://`. Example: `http://127.0.0.1:11434`"
                    },
                    "collama.apiModelCompletion": {
                        "type": "string",
                        "default": "",
                        "description": "Model for autocomplete."
                    },
                    "collama.apiTokenContextLenCompletion": {
                        "type": "number",
                        "default": 32000,
                        "description": "Context window size (tokens) for the completion model."
                    },
                    "collama.apiTokenPredictCompletion": {
                        "type": "number",
                        "default": 400,
                        "description": "Max tokens to generate per completion request."
                    }
                }
            },
            {
                "title": "Instruct-API",
                "properties": {
                    "collama.apiEndpointInstruct": {
                        "type": "string",
                        "default": "",
                        "markdownDescription": "API endpoint for edit/chat.\n\nStarts with `http://` or `https://`. Example: `http://127.0.0.1:11434`"
                    },
                    "collama.apiModelInstruct": {
                        "type": "string",
                        "default": "",
                        "markdownDescription": "Model for edits.\n\nUse an **instruct** or **base** model."
                    },
                    "collama.apiTokenContextLenInstruct": {
                        "type": "number",
                        "default": 128000,
                        "description": "Context window size (tokens) for the instruct/chat model."
                    },
                    "collama.apiTokenPredictInstruct": {
                        "type": "number",
                        "default": 8000,
                        "description": "Max tokens to generate per instruct/chat request."
                    }
                }
            },
            {
                "title": "General",
                "properties": {
                    "collama.tlsRejectUnauthorized": {
                        "type": "boolean",
                        "default": false,
                        "markdownDescription": "Verify TLS certificates for HTTPS endpoints. **Disable only if you trust the network** (equivalent to `NODE_TLS_REJECT_UNAUTHORIZED=0`)."
                    },
                    "collama.autoComplete": {
                        "type": "boolean",
                        "default": false,
                        "description": "Turn auto-suggestions ON."
                    },
                    "collama.suggestMode": {
                        "type": "string",
                        "default": "inline",
                        "enum": [
                            "inline",
                            "multiblock",
                            "multiline"
                        ],
                        "markdownDescription": "Suggest code-blocks or code-lines."
                    },
                    "collama.verbosityMode": {
                        "type": "string",
                        "default": "medium",
                        "enum": [
                            "compact",
                            "medium",
                            "detailed"
                        ],
                        "markdownDescription": "Controls how concise or detailed chat responses should be."
                    },
                    "collama.suggestDelay": {
                        "type": "number",
                        "default": 1500,
                        "markdownDescription": "Delay (ms) before requesting inline completion. Prevents Ollama from running every time the completion is triggered. (Spam protection)\n\n**Min:** 1000"
                    },
                    "collama.agenticMode": {
                        "type": "boolean",
                        "default": true,
                        "description": "Use agentic (tool use) mode for chat."
                    },
                    "collama.enableEditTools": {
                        "type": "boolean",
                        "default": true,
                        "description": "Enable edit tools (write, create, delete). When disabled, the agent runs in read-only mode."
                    },
                    "collama.enableShellTool": {
                        "type": "boolean",
                        "default": false,
                        "description": "Enable the shell tool. When disabled, shell command execution is unavailable to the agent."
                    },
                    "collama.liteMode": {
                        "type": "boolean",
                        "default": false,
                        "description": "Lite-Mode. When enabled, the agent system prompt is reduced to a minimal form. Useful for small models that struggle with longer system prompts."
                    },
                    "collama.searxngEndpoint": {
                        "type": "string",
                        "default": "",
                        "markdownDescription": "SearXNG server for the agent's web search tool.\n\nStarts with `http://` or `https://`. Example: `http://127.0.0.1:8888`\n\nThe search tool is only offered to the agent while the server is reachable. The instance must have the `json` output format enabled."
                    },
                    "collama.extraBody": {
                        "type": "object",
                        "default": {},
                        "markdownDescription": "Extra JSON body fields for every LLM request (Instruct). Use for provider-specific params like `chat_template_kwargs` for thinking/reasoning.\n\nExample:\n```json\n{\n    \"chat_template_kwargs\": {\n        \"thinking\": true,\n        \"reasoning_effort\": \"high\"\n    }\n}\n```"
                    }
                }
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "collama_chat",
                    "title": "collama",
                    "icon": "media/collama_chat.svg"
                }
            ]
        },
        "views": {
            "collama_chat": [
                {
                    "id": "collama_chatview",
                    "name": "Chat",
                    "type": "webview",
                    "icon": "media/collama_chat.svg"
                }
            ]
        },
        "commands": [
            {
                "command": "collama.writeDocstrings",
                "title": "Write Docstring"
            },
            {
                "command": "collama.extractFunctions",
                "title": "Extract Functions"
            },
            {
                "command": "collama.simplifyCode",
                "title": "Simplify Code"
            },
            {
                "command": "collama.fixSyntax",
                "title": "Fix Syntax"
            },
            {
                "command": "collama.editManual",
                "title": "Edit"
            },
            {
                "command": "collama.sendToChat",
                "title": "Send to Chat"
            },
            {
                "command": "collama.requestCommitMessage",
                "title": "collama: Generate Commit Message",
                "icon": "$(sparkle)"
            },
            {
                "command": "collama.setBearerCompletion",
                "title": "collama: Set Bearer Token (Completion)"
            },
            {
                "command": "collama.setBearerInstruct",
                "title": "collama: Set Bearer Token (Instruct)"
            },
            {
                "command": "collama.acceptEdit",
                "title": "collama: Accept Changes",
                "icon": "$(check)"
            },
            {
                "command": "collama.rejectEdit",
                "title": "collama: Discard Changes",
                "icon": "$(close)"
            }
        ],
        "submenus": [
            {
                "id": "collama.submenu1",
                "label": "collama"
            }
        ],
        "menus": {
            "scm/inputBox": [
                {
                    "command": "collama.requestCommitMessage",
                    "when": "scmProvider == git"
                }
            ],
            "editor/context": [
                {
                    "submenu": "collama.submenu1",
                    "group": "0_collama",
                    "when": "activeEditor"
                }
            ],
            "explorer/context": [
                {
                    "submenu": "collama.submenu1",
                    "group": "0_collama"
                }
            ],
            "collama.submenu1": [
                {
                    "command": "collama.writeDocstrings",
                    "group": "1_actions",
                    "when": "editorHasSelection"
                },
                {
                    "command": "collama.extractFunctions",
                    "group": "1_actions",
                    "when": "editorHasSelection"
                },
                {
                    "command": "collama.simplifyCode",
                    "group": "1_actions",
                    "when": "editorHasSelection"
                },
                {
                    "command": "collama.fixSyntax",
                    "group": "1_actions",
                    "when": "editorHasSelection"
                },
                {
                    "command": "collama.editManual",
                    "group": "2_edit",
                    "when": "editorHasSelection"
                },
                {
                    "command": "collama.sendToChat",
                    "group": "3_send"
                }
            ],
            "scm/title": [
                {
                    "command": "collama.requestCommitMessage",
                    "group": "navigation",
                    "when": "scmProvider == git"
                }
            ],
            "editor/title": [
                {
                    "command": "collama.acceptEdit",
                    "group": "navigation@1",
                    "when": "collama.diffPreviewActive"
                },
                {
                    "command": "collama.rejectEdit",
                    "group": "navigation@2",
                    "when": "collama.diffPreviewActive"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "npm run check-types && npm run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "npm run check-types && npm run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/diff": "^7.0.2",
        "@types/markdown-it": "^14.1.2",
        "@types/node": "25.x",
        "@types/vscode": "^1.120.0",
        "esbuild": "^0.28.0",
        "esbuild-plugin-inline-import": "^1.1.0",
        "eslint": "^10.4.1",
        "fastest-levenshtein": "^1.0.16",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1"
    },
    "dependencies": {
        "@fontsource/jetbrains-mono": "^5.2.8",
        "@fontsource/roboto": "^5.2.10",
        "@microsoft/tiktokenizer": "^1.0.10",
        "diff": "^9.0.0",
        "globby": "^16.2.0",
        "highlight.js": "^11.11.1",
        "lit": "^3.3.3",
        "lucide": "^1.17.0",
        "markdown-it": "^14.2.0",
        "micromatch": "^4.0.8",
        "node-fetch": "^3.3.2",
        "ollama": "^0.6.3",
        "openai": "^6.41.0"
    }
}
